<% layout("/Layouts/boilerplate") %>
<body>
        <h2 class="offset-5 update"> Add new place </h2>

        <div class="row">
            <div class="col-8 offset-2">
                <form action="/mainListings/addListing" method="post" novalidate class="needs-validation">
                        <div class="mb-3">
                                <label for="text" class="form-label cols"> Enter the title :</label>
                                <input type="text" name="newPlace[title]" placeholder="Enter the title"  class="form-control" > 
                                <div class="valid-feedback">Looks good!</div>
                                <div class="invalid-feedback">Invalid Title</div>
                        </div>
                        <div class="mb-3">
                                <label for="description" class="form-label">Enter the description : </label><br> 
                                <textarea type="text" name="newPlace[description]" rows="6" cols="50" class="form-control" placeholder="Enter the description" ></textarea>
                                <div class="valid-feedback">Looks good!</div>
                                <div class="invalid-feedback">Invalid Description</div>
                        </div>

                       <div class="row ">
                                 <div class="mb-3 col-md-5">
                                        <label for="price" class="form-label">Enter the price : </label>
                                        <input type="text" name="newPlace[price]" class="form-control" placeholder="Enter the price">
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Invalid Price</div>
                                </div>

                                <div class="mb-3 col-md-7">
                                        <label for="country" class="form-label"> Enter the country  :</label> 
                                        <input type="text" name="newPlace[country]"  class="form-control" placeholder="Enter the country name">
                                        <div class="valid-feedback">Looks good!</div>
                                        <div class="invalid-feedback">Invalid country</div>

                                </div>
                       </div>

                        <div class="mb-3">
                                <label for="image" class="form-label">image link/url :</label>
                                <input type="text" name="newPlace[image]" class="form-control" placeholder="Enter the image link">
                                <!-- <div class="valid-feedback">Looks good!</div> -->
                        </div>

                        <div class="mb-3">
                                <label for="location" class="form-label">Enter the location : </label>
                                <input type="text" name="newPlace[location]"  class="form-control" placeholder="Enter the location">
                                <div class="valid-feedback">Looks good!</div>
                                <div class="invalid-feedback">Invalid Location</div>
                        </div>

                        
                       <br> <button type="submit" class="btn add-btn offset-5"> Add Place</button>  <br>
                      <br><br><br>

                </form>
            </div>     
        </div>
</body>
