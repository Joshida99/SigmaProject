<% layout("/Layouts/boilerplate") -%>
<body>
    
    <!-- dataOfId is the object which holds the values of this current place / object-->


  
    <!-- To Show the Current Place in Detail -->
<div class="row">
        <div class="col-8 offset-2">
                        
            <div class="card" style="width: 50rem;">

                <br> <h5 class="card-title title_card "><%= dataOfId.title %></h5> <br>
                <img src="<%= dataOfId.image %> " class="card-img-top" style="height: 30rem;" alt="Place_Image">

                <div class="card-body">
                        <h6><i>Owner : <%= dataOfId.owner.username %></i></h6>
                        <p class="card-text carddesc "><%= dataOfId.description %></p>
                        <p> Price :  &#8377;<%= dataOfId.price.toLocaleString("en-IN")%> </p>
                        <p>Location :  <%= dataOfId.location %> </p>
                        <p>Country :  <%= dataOfId.country %> </p> 

                        <% if(currUser && currUser._id.equals(dataOfId.owner._id)){ %> 
                        <div class="btns offset-4">
                                <a href="/mainListings/<%=dataOfId._id%>/update" class="btn btn-danger edit-btn">Update Place</a>
                                <a href="/mainListings/<%=dataOfId._id%>/delete" class="btn btn-dark">Delete Place</a>
                        </div><br>  
                        <% } %>                           
                </div>
            </div> 
        </div>
</div>





<!-- Add Review -->
          
    <div class="col-8 offset-2">  
           
        <% if(currUser){ %>    <hr><hr> 
            <h3 class="col-8 offset-5"> Leave a Review </h3>
            <form action="/mainListings/<%= dataOfId._id %>/reviews" method="post" novalidate class="needs-validation">
                    <!-- <div class="mb-3 mt-3">
                        <label for="rating" class="form-label"><h5>Rating : </h5></label>
                        <input type="range" min="1" max="5" id="rating" name="Review[rating]" class="form-range">
                    </div> -->
 
                <div class="mb-3 mt-3">
                        <label for="rating" class="form-label"><h5>Rating : </h5></label>
                    <fieldset class="starability-slot">

                        <input type="radio" id="no-rate" class="input-no-rate" name="Review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="Review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="Review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="Review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="Review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="Review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>


                    <div class="mb-3 mt-3">
                        <label for="comment" class="form-label" ><h5>Comment</h5></label> <br>
                        <textarea name="Review[comment]" id="comment" cols="49" rows="5" class="form-control" placeholder="Leave A Comment..." required></textarea> 
                        <div class="invalid-feedback">Please add Your Review!!</div>
                        <br>
                    </div>
                    <button class="btn btn-dark offset-5" class="mb-3 mt-3">Submit</button> <br><br>
            </form>
        <% } %>

        <hr>
     
     <!-- Show Reviews -->

        <h4>All Reviews</h4>
        <!-- <p><%=dataOfId.reviews%></p> -->
        <div class="row">
            <% for(review of dataOfId.reviews){ %>
    
                <div class="card border mb-3 col-5 ms-3">
                    <h5 class="card-title">@<%= review.author.username %></h5>
                    <p class="starability-result" data-rating="<%= review.rating %>">
                        Rated: 3 stars
                    </p>
                    <p class="card-text"><%= review.comment %></p> 
                    <form method="post" class="mb-3 button" action="/mainListings/<%= dataOfId._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button type="submit" class="btn btn-dark">Delete Review</button>
                    </form>                 
                </div>
                
        
            <% } %>

        </div>

    </div>
     
</body>


